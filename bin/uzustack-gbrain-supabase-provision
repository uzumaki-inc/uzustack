#!/usr/bin/env bash
# uzustack-gbrain-supabase-provision — /setup-gbrain path 2a (auto-provision)
# 用の Supabase Management API ラッパー。
#
# Subcommand:
#   list-orgs
#     GET /v1/organizations。 Output: {"orgs": [{"slug","name"}, ...]}
#
#   create <name> <region> <org-slug>
#     POST /v1/projects に {name, db_pass, organization_slug, region}。
#     db_pass は DB_PASS env 経由 (argv 不可 — D8 の grep test で enforce)。
#     Output: {"ref","name","region","organization_slug","status"}。
#
#     NOTE: `plan` field は送らない。検証済みの Supabase Management API
#     OpenAPI によれば `plan` field は project 単位では deprecated —
#     subscription tier は org 単位の決定 (D17 update)。
#
#   wait <ref> [--timeout <seconds>]
#     GET /v1/projects/{ref} を 5s 毎 poll し、status=ACTIVE_HEALTHY まで待つ。
#     terminal state (INIT_FAILED / REMOVED) なら fail。default timeout 180s。
#     成功時 Output: {"ref","status","elapsed_s"}。
#
#   pooler-url <ref>
#     GET /v1/projects/{ref}/config/database/pooler を取り、env の DB_PASS を
#     使って full Session Pooler URL を構築する (API response の
#     connection_string は通常 [PASSWORD] template で実値ではない — 代わりに
#     db_user/db_host/db_port/db_name から組み立てる)。
#     Output: {"ref","pooler_url"}。
#
#   list-orphans [--name-prefix <str>]
#     GET /v1/projects。name が --name-prefix (default "gbrain") で始まり、
#     かつ ref が現 active な ~/.gbrain/config.json の pooler URL の ref と
#     一致しないものを filter する。動く local config が指していない
#     gbrain-shaped project — /setup-gbrain --cleanup-orphans の候補。
#     Output: {"active_ref","orphans":[{"ref","name","created_at","region"}, ...]}。
#
#   delete-project <ref>
#     DELETE /v1/projects/{ref}。Destructive で one-way — caller は呼ぶ前に
#     double-confirm すべき。本 binary は確認 prompt をしない、UI 層の責務。
#     Output: {"deleted_ref"}。
#
# Secrets discipline (D8 / D10 / D11):
#   - SUPABASE_ACCESS_TOKEN は env から read、argv では絶対 accept しない。
#   - DB_PASS (`create` と `pooler-url` 用) は env から read、argv 不可。
#   - 禁止文字列 (skill-validation の grep test で enforce):
#       --insecure、-k (curl)、NODE_TLS_REJECT_UNAUTHORIZED
#   - default `set +x` — debug mode は非 secret 行周辺で明示的に opt-in する。
#
# Env:
#   SUPABASE_ACCESS_TOKEN — auth 用 PAT (全 subcommand で必要)
#   DB_PASS               — db password (create + pooler-url で必要)
#   SUPABASE_API_BASE     — API host を override (test は local mock を指す)。
#                           default: https://api.supabase.com
#
# Exit code:
#   0 — 成功
#   2 — usage / 入力不正
#   3 — auth 失敗 (401/403) — fresh PAT で retry
#   4 — quota / billing (402) — user の対応が必要
#   5 — conflict (409) — 重複名、user の対応が必要
#   6 — timeout (wait subcommand が deadline に達した)
#   7 — Supabase 側の terminal failure state (INIT_FAILED / REMOVED)
#   8 — network / 5xx (retry 後)
set +x  # defensive: 本 helper では secret を絶対 trace しない
set -euo pipefail

SUPABASE_API_BASE="${SUPABASE_API_BASE:-https://api.supabase.com}"
API_VERSION="v1"
DEFAULT_WAIT_TIMEOUT=180
POLL_INTERVAL=5
CURL_TIMEOUT=30

die()     { echo "uzustack-gbrain-supabase-provision: $*" >&2; exit 2; }
die_auth() { echo "uzustack-gbrain-supabase-provision: $*" >&2; exit 3; }
die_quota(){ echo "uzustack-gbrain-supabase-provision: $*" >&2; exit 4; }
die_conflict(){ echo "uzustack-gbrain-supabase-provision: $*" >&2; exit 5; }
die_net() { echo "uzustack-gbrain-supabase-provision: $*" >&2; exit 8; }

require_jq() {
  command -v jq >/dev/null 2>&1 || die "jq が必要。install: brew install jq"
}
require_curl() {
  command -v curl >/dev/null 2>&1 || die "curl が必要"
}

require_pat() {
  if [ -z "${SUPABASE_ACCESS_TOKEN:-}" ]; then
    die_auth "SUPABASE_ACCESS_TOKEN が未設定。PAT を https://supabase.com/dashboard/account/tokens で生成する"
  fi
}

require_db_pass() {
  if [ -z "${DB_PASS:-}" ]; then
    die "DB_PASS env が必要 (argv 経由禁止 — ps / history で leak する)"
  fi
}

# api_call <method> <path> [<json-body-file>]
# 処理: 401/403 → exit 3、402 → 4、409 → 5、429 + 5xx → 最大 3 attempt の
# 指数 backoff。stdout に response body、HTTP status は内部変数で pipe trick 経由。
#
# bash は multi-value return ができないので、response body を tmpfile に、
# status を別 tmpfile に書き、caller が両方を読む。
api_call() {
  local method="$1"
  local apipath="$2"
  local body_file="${3:-}"

  local url="$SUPABASE_API_BASE/$API_VERSION/$apipath"
  local body_tmp
  body_tmp=$(mktemp)
  local status_tmp
  status_tmp=$(mktemp)
  # shellcheck disable=SC2064
  trap "rm -f '$body_tmp' '$status_tmp'" RETURN

  local attempt=0
  local max_attempts=3
  local backoff=2
  while : ; do
    attempt=$((attempt + 1))
    local curl_args=(
      --silent
      --show-error
      --max-time "$CURL_TIMEOUT"
      -o "$body_tmp"
      -w "%{http_code}"
      -X "$method"
      -H "Authorization: Bearer $SUPABASE_ACCESS_TOKEN"
      -H "Accept: application/json"
      -H "Content-Type: application/json"
      -H "User-Agent: uzustack-gbrain-supabase-provision"
    )
    if [ -n "$body_file" ]; then
      curl_args+=(--data-binary "@$body_file")
    fi
    local status
    if ! status=$(curl "${curl_args[@]}" "$url" 2>/dev/null); then
      # curl 自体が失敗 (network / timeout 等)。retry。
      if [ "$attempt" -ge "$max_attempts" ]; then
        die_net "$method $apipath への network failure ($attempt 回試行後)"
      fi
      sleep "$backoff"
      backoff=$((backoff * 2))
      continue
    fi

    case "$status" in
      2??)
        cat "$body_tmp"
        printf '%s' "$status" > "$status_tmp"
        return 0
        ;;
      401)
        die_auth "401 Unauthorized — PAT が無効か期限切れ。https://supabase.com/dashboard/account/tokens で再生成する"
        ;;
      403)
        die_auth "403 Forbidden — PAT に $method $apipath への権限が無い。All Access scope で再生成する"
        ;;
      402)
        die_quota "402 Payment Required — Supabase project / organization quota を超過。https://supabase.com/dashboard を確認"
        ;;
      409)
        die_conflict "409 Conflict on $method $apipath — 重複 project 名の可能性。別名で再実行する"
        ;;
      429|5??)
        if [ "$attempt" -ge "$max_attempts" ]; then
          die_net "$method $apipath で $status ($attempt 回試行後)"
        fi
        sleep "$backoff"
        backoff=$((backoff * 2))
        continue
        ;;
      *)
        # 400 / 404 等 — debug 用に error body を surface する
        local err
        err=$(jq -r '.message // .error // empty' "$body_tmp" 2>/dev/null || true)
        if [ -n "$err" ]; then
          die "HTTP $status from $method $apipath: $err"
        else
          die "HTTP $status from $method $apipath (response に error message 無し)"
        fi
        ;;
    esac
  done
}

cmd_list_orgs() {
  local json_mode=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) json_mode=true; shift ;;
      *) die "list-orgs: 不明な flag: $1" ;;
    esac
  done

  require_jq; require_curl; require_pat
  local resp
  resp=$(api_call GET organizations)
  if $json_mode; then
    printf '%s' "$resp" | jq '{orgs: map({slug: .slug, name: .name})}'
  else
    printf '%s' "$resp" | jq -r '.[] | "\(.slug)\t\(.name)"'
  fi
}

cmd_create() {
  local name="" region="" org_slug=""
  local json_mode=false
  local instance_size=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) json_mode=true; shift ;;
      --instance-size) instance_size="$2"; shift 2 ;;
      --*) die "create: 不明な flag: $1" ;;
      *)
        if   [ -z "$name" ]; then name="$1"
        elif [ -z "$region" ]; then region="$1"
        elif [ -z "$org_slug" ]; then org_slug="$1"
        else die "create: positional argument が多すぎる"
        fi
        shift
        ;;
    esac
  done
  [ -z "$name" ] && die "create: <name> が無い"
  [ -z "$region" ] && die "create: <region> が無い"
  [ -z "$org_slug" ] && die "create: <org-slug> が無い"

  require_jq; require_curl; require_pat; require_db_pass

  local body_file
  body_file=$(mktemp)
  # shellcheck disable=SC2064
  trap "rm -f '$body_file'" RETURN
  if [ -n "$instance_size" ]; then
    jq -n \
      --arg name "$name" \
      --arg db_pass "$DB_PASS" \
      --arg organization_slug "$org_slug" \
      --arg region "$region" \
      --arg desired_instance_size "$instance_size" \
      '{name: $name, db_pass: $db_pass, organization_slug: $organization_slug, region: $region, desired_instance_size: $desired_instance_size}' \
      > "$body_file"
  else
    jq -n \
      --arg name "$name" \
      --arg db_pass "$DB_PASS" \
      --arg organization_slug "$org_slug" \
      --arg region "$region" \
      '{name: $name, db_pass: $db_pass, organization_slug: $organization_slug, region: $region}' \
      > "$body_file"
  fi

  local resp
  resp=$(api_call POST projects "$body_file")
  if $json_mode; then
    printf '%s' "$resp" | jq '{ref, name, region, organization_slug, status}'
  else
    printf '%s' "$resp" | jq -r '"ref=\(.ref) status=\(.status) region=\(.region)"'
  fi
}

cmd_wait() {
  local ref="" timeout="$DEFAULT_WAIT_TIMEOUT"
  local json_mode=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --timeout) timeout="$2"; shift 2 ;;
      --json) json_mode=true; shift ;;
      --*) die "wait: 不明な flag: $1" ;;
      *) ref="$1"; shift ;;
    esac
  done
  [ -z "$ref" ] && die "wait: <ref> が無い"

  require_jq; require_curl; require_pat

  local elapsed=0
  while : ; do
    local resp
    resp=$(api_call GET "projects/$ref")
    local status
    status=$(printf '%s' "$resp" | jq -r '.status // "UNKNOWN"')
    case "$status" in
      ACTIVE_HEALTHY)
        if $json_mode; then
          jq -n --arg ref "$ref" --arg status "$status" --argjson elapsed "$elapsed" \
            '{ref: $ref, status: $status, elapsed_s: $elapsed}'
        else
          echo "ready ref=$ref status=$status elapsed_s=$elapsed"
        fi
        return 0
        ;;
      INIT_FAILED|REMOVED|RESTORE_FAILED|PAUSE_FAILED)
        echo "uzustack-gbrain-supabase-provision: project $ref が terminal failure state '$status' に到達" >&2
        exit 7
        ;;
      COMING_UP|INACTIVE|ACTIVE_UNHEALTHY|UNKNOWN|RESTORING|UPGRADING|PAUSING|RESTARTING|RESIZING|GOING_DOWN)
        # provisioning 中 — poll 継続
        ;;
      *)
        # Supabase からの想定外 status。log するが poll は継続。
        echo "uzustack-gbrain-supabase-provision: 想定外 status '$status' — poll 継続" >&2
        ;;
    esac

    if [ "$elapsed" -ge "$timeout" ]; then
      echo "uzustack-gbrain-supabase-provision: wait が ${timeout}s で timeout (last status: $status)" >&2
      echo "uzustack-gbrain-supabase-provision: /setup-gbrain --resume-provision $ref で再実行する" >&2
      exit 6
    fi
    sleep "$POLL_INTERVAL"
    elapsed=$((elapsed + POLL_INTERVAL))
  done
}

cmd_pooler_url() {
  local ref=""
  local json_mode=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) json_mode=true; shift ;;
      --*) die "pooler-url: 不明な flag: $1" ;;
      *) ref="$1"; shift ;;
    esac
  done
  [ -z "$ref" ] && die "pooler-url: <ref> が無い"

  require_jq; require_curl; require_pat; require_db_pass

  local resp
  resp=$(api_call GET "projects/$ref/config/database/pooler")

  # Supabase が array を返した時、singular な Session Pooler config を優先する
  # (response shape は project state によって変わる)。"session" pool_mode が
  # 無ければ最初の PRIMARY entry に fallback する。
  local db_user db_host db_port db_name
  local first_or_session
  if printf '%s' "$resp" | jq -e 'type == "array"' >/dev/null 2>&1; then
    first_or_session=$(printf '%s' "$resp" | jq '[.[] | select(.pool_mode == "session")][0] // .[0]')
  else
    first_or_session="$resp"
  fi

  db_user=$(printf '%s' "$first_or_session" | jq -r '.db_user // empty')
  db_host=$(printf '%s' "$first_or_session" | jq -r '.db_host // empty')
  db_port=$(printf '%s' "$first_or_session" | jq -r '.db_port // empty')
  db_name=$(printf '%s' "$first_or_session" | jq -r '.db_name // empty')

  if [ -z "$db_user" ] || [ -z "$db_host" ] || [ -z "$db_port" ] || [ -z "$db_name" ]; then
    die "pooler-url: pooler config field が不足 (db_user/db_host/db_port/db_name); re-poll するか project state を確認"
  fi

  local url="postgresql://${db_user}:${DB_PASS}@${db_host}:${db_port}/${db_name}"

  if $json_mode; then
    jq -n --arg ref "$ref" --arg pooler_url "$url" '{ref: $ref, pooler_url: $pooler_url}'
  else
    # non-JSON mode は URL を出す。caller が変数に capture すれば
    # process memory に留まる。
    echo "$url"
  fi
}

cmd_list_orphans() {
  local name_prefix="gbrain"
  local json_mode=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --name-prefix) name_prefix="$2"; shift 2 ;;
      --json) json_mode=true; shift ;;
      --*) die "list-orphans: 不明な flag: $1" ;;
      *) die "list-orphans: 想定外 arg: $1" ;;
    esac
  done

  require_jq; require_curl; require_pat
  local all
  all=$(api_call GET projects)

  # active brain の ref を ~/.gbrain/config.json から取り出す (存在すれば)。
  # Pooler URL format: postgresql://postgres.<ref>:<pw>@...
  local active_ref="null"
  local gbrain_cfg="$HOME/.gbrain/config.json"
  if [ -f "$gbrain_cfg" ]; then
    local url
    url=$(jq -r '.database_url // empty' "$gbrain_cfg" 2>/dev/null || true)
    if [ -n "$url" ]; then
      # colon より前の user 部分を取る: postgresql://USER:pw@...
      local user
      user=$(printf '%s' "$url" | sed -E 's|^[a-z]+://([^:]+):.*$|\1|')
      # user 形式: postgres.<ref> — ref suffix を引き出す
      case "$user" in
        postgres.*)
          local ref="${user#postgres.}"
          active_ref=$(jq -Rn --arg r "$ref" '$r')
          ;;
      esac
    fi
  fi

  local orphans
  orphans=$(printf '%s' "$all" | jq \
    --arg prefix "$name_prefix" \
    --argjson active "$active_ref" \
    '[.[]
       | select(.name | startswith($prefix))
       | select(.ref != $active)
       | {ref: .ref, name: .name, created_at: .created_at, region: .region}]')

  jq -n --argjson active "$active_ref" --argjson orphans "$orphans" \
    '{active_ref: $active, orphans: $orphans}'
}

cmd_delete_project() {
  local ref=""
  local json_mode=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) json_mode=true; shift ;;
      --*) die "delete-project: 不明な flag: $1" ;;
      *) ref="$1"; shift ;;
    esac
  done
  [ -z "$ref" ] && die "delete-project: <ref> が無い"

  require_jq; require_curl; require_pat
  api_call DELETE "projects/$ref" >/dev/null
  jq -n --arg ref "$ref" '{deleted_ref: $ref}'
}

case "${1:-}" in
  list-orgs)        shift; cmd_list_orgs "$@" ;;
  create)           shift; cmd_create "$@" ;;
  wait)             shift; cmd_wait "$@" ;;
  pooler-url)       shift; cmd_pooler_url "$@" ;;
  list-orphans)     shift; cmd_list_orphans "$@" ;;
  delete-project)   shift; cmd_delete_project "$@" ;;
  --help|-h|help)   sed -n '2,80p' "$0" | sed 's/^# \{0,1\}//' ;;
  "")  die "usage: uzustack-gbrain-supabase-provision {list-orgs|create|wait|pooler-url|list-orphans|delete-project|--help}" ;;
  *)   die "不明な subcommand: $1" ;;
esac
